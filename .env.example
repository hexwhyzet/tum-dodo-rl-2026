# Copy to .env and fill in values
# cp .env.example .env

# Weights & Biases
WANDB_API_KEY=your_key_here
WANDB_PROJECT=dodo-rl
WANDB_ENTITY=your_username

# Vast.ai
VAST_API_KEY=your_key_here

# Cloud storage for checkpoints (S3 or HuggingFace)
HF_TOKEN=your_token_here
HF_REPO=your_username/dodo-rl-checkpoints

# Training
SEED=42
NUM_ENVS=4096
HEADLESS=true
